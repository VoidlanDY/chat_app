# ChatApp 服务器环境变量配置示例
# 复制此文件为 .env 并填入实际的密钥值

# ==================== AI 服务 ====================

# DeepSeek AI API 密钥
# 用于 AI 机器人功能
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ==================== 推送通知服务 ====================

# Firebase Cloud Messaging (FCM) - 国际推送
# 项目 ID（可选，默认为 chatapp-ae10f）
FCM_PROJECT_ID=your-fcm-project-id

# 极光推送 (JPush) - 国内推送
# 获取地址: https://www.jiguang.cn/
JPUSH_APP_KEY=your-jpush-app-key
JPUSH_MASTER_SECRET=your-jpush-master-secret

# ==================== 数据库配置 ====================

# MySQL/MariaDB 数据库配置
# 注意：这些配置也可以在代码中设置
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-db-password
# DB_NAME=chat_app

# ==================== 安全提示 ====================

# 1. 不要将此文件提交到版本控制系统
# 2. 确保 .env 文件权限设置为 600 (仅所有者可读写)
# 3. 定期轮换 API 密钥
# 4. 在生产环境中使用强密码和密钥
